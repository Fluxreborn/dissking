{
  "_comment": "屏蔽词绕过系统 - 用替代方式表达敏感内容",
  
  "绕过规则": {
    "谐音替换": {
      "说明": "声母/韵母替换，保持读音相似",
      "规则": {
        "sh": "x", "ch": "q", "zh": "z",
        "ang": "an", "eng": "en", "ing": "in"
      }
    },
    "拼音缩写": {
      "说明": "取首字母",
      "示例": "qnmlgb = 问候语, wqnmlgb = 加强版"
    },
    "形近字": {
      "说明": "用形近字替代",
      "规则": {
        "日": "曰", "币": "巾", "草": "艹",
        "妈": "马", "逼": "B", "傻": "shǎ"
      }
    },
    "Emoji替代": {
      "说明": "用emoji表达情绪",
      "映射": {
        "🐎": "马", "🌿": "草", "🐔": "鸡",
        "🧠": "脑", "💩": "屎", "🤡": "小丑"
      }
    },
    "拆字": {
      "说明": "拆解汉字部件",
      "规则": {
        "骂": "马+骂", "屁": "尸+比", "粪": "米+共"
      }
    },
    "间隔符": {
      "说明": "用符号间隔",
      "模式": "{char}*{char}*{char}"
    },
    "火星文": {
      "说明": "使用异体字",
      "示例": "莪, 伱, ㄋ, ㄉ"
    }
  },

  "情绪词库": {
    "愤怒": {
      "直接": ["垃圾", "废物", "渣", "烂"],
      "绕过": ["辣鸡", "fei物", "渣渣", "lan"]
    },
    "鄙视": {
      "直接": ["装逼", "傻X", "白痴"],
      "绕过": ["装X", "shǎX", "白chi"]
    },
    "嘲讽": {
      "直接": ["呵呵", "哈哈", "笑死"],
      "绕过": ["呵呵😅", "哈哈🤣", "孝死"]
    }
  },

  "转换器": {
    "基础替换": {
      "fuck": "f**k",
      "shit": "sh*t",
      "bitch": "b***h"
    },
    "拼音替换": {
      "他妈": "tm", "他妈的": "tmd",
      "傻逼": "sb", "傻叉": "sx",
      "脑残": "nc", "垃圾": "lj"
    },
    "谐音替换": {
      "滚": "棍", "死": "si", "操": "cao",
      "逼": "B", "屌": "dio", "粪": "fen"
    },
    "emoji增强": {
      "讽刺": "😅🤣", "鄙视": "😒🙄", "愤怒": "🤬💢",
      "无语": "😑😶", "阴阳": "🥺🥰"
    }
  }
}
